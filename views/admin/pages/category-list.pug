extends ../layouts/default.pug


block main
  h1.box-title Quản lý danh mục

  //- Section 4
  .section-4
    .inner-wrap
      .inner-item.inner-label
        <i class="fa-solid fa-filter"></i> Bộ  
      .inner-item
        select(filter-status)
          option(value="") Trạng thái
          option(value="active") Hoạt động
          option(value="inactive") Tạm dừng
      .inner-item
        select(filter-created-by)
          option(value="") Người tạo
          each item in userAdmin
            option(value=item.id) #{item.fullName}
      .inner-item.inner-date
        input(type="date" filter-start-date)
        span -
        input(type="date" filter-end-date)
      .inner-item.inner-reset(delete-filter-button)
        <i class="fa-solid fa-rotate-left" ></i> Xóa bộ lọc
  //- End Section 4

  //- Section 5
  .section-5
    .inner-wrap
      .inner-change-status(
        change-multi 
        data-api=`/${pathAdmin}/category/change-multi`
        )
        .inner-item
          select
            option(value="") -- Hành động --
            option(value="active") Hoạt động
            option(value="inactive") Tạm dừng
            option(value="delete") Xóa
        .inner-item
          button Áp dụng
      .inner-search
        <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text" placeholder="Tìm kiếm" search)
      .inner-button-create
        a(href=`/${pathAdmin}/category/create`) + Tạo mới
  //- End Section 5

  //- Section 6
  .section-6
    .table-2
      table
        thead
          tr
            th(class="inner-center")
              input(type="checkbox" class="inner-check" check-all)
            th Tên danh mục
            th Ảnh đại diện
            th(class="inner-center") Vị trí
            th(class="inner-center") Trạng thái
            th Tạo bởi
            th Cập nhật bởi
            th Hành động
        tbody
          each item in categoryList
            tr
              td(class="inner-center")
                input(type="checkbox" class="inner-check" check-item = item.id)
              td #{item.name}
              td
                img(src=item.avatar class="inner-avatar")
              td(class="inner-center") #{item.position}
              td(class="inner-center")
                if(item.status == "active")
                  .badge.badge-green Hoạt động
                else if(item.status == "inactive")
                  .badge.badge-red Tạm dừng
              td
                div #{item.createdByAdmin}
                div.inner-time #{item.createdAtFormat}
              td
                div #{item.updatedByAdmin}
                div.inner-time #{item.updatedAtFormat}
              td
                .inner-buttons
                  a(
                    href=`/${pathAdmin}/category/edit/${item.id}`
                    class="inner-edit"
                    ) 
                   <i class="fa-regular fa-pen-to-square"></i>
                  button(class="inner-delete" button-delete data-api=`/${pathAdmin}/category/delete/${item.id}`) <i class="fa-regular fa-trash-can"></i>
  //- End Section 6

  //- Section 7
  .section-7
    span(class="inner-label") Hiển thị #{pagination.startItem} - #{pagination.endItem} của #{pagination.totalRecord}
    .inner-pagination(box-pagination)
      button(
        type="button"
        class="inner-page inner-page-nav"
        data-page=(pagination.currentPage - 1)
        disabled=(pagination.currentPage <= 1)
      ) Trước
      - for(let i = 1; i <= pagination.totalPage; ++i)
        button(
          type="button"
          class=`inner-page ${pagination.currentPage === i ? "active" : ""}`
          data-page=i
        ) #{i}
      button(
        type="button"
        class="inner-page inner-page-nav"
        data-page=(pagination.currentPage + 1)
        disabled=(pagination.currentPage >= pagination.totalPage)
      ) Sau
  //- End Section 7
