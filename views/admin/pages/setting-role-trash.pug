extends ../layouts/default.pug

block main
  h1.box-title Thùng rác nhóm quyền

  //- Section 5
  .section-5
    .inner-wrap
      .inner-change-status(change-multi data-api=`/${pathAdmin}/setting/role/change-multi`)
        .inner-item
          select
            option(value="") -- Hành động --
            option(value="undo") Khôi phục
            option(value="destroy") Xóa vĩnh viễn
        .inner-item
          button Áp dụng
      .inner-search
        i.fa-solid.fa-magnifying-glass
        input(type="text" placeholder="Tìm kiếm" search)
      .inner-button-create
        a(href=`/${pathAdmin}/setting/role/list`) Quay lại danh sách
  //- End Section 5

  //- Section 6
  .section-6
    .table-2
      table
        thead
          tr
            th.inner-center
              input.inner-check(type="checkbox" check-all)
            th Tên nhóm quyền
            th Mô tả ngắn
            th Xóa bởi
            th Hành động
        tbody
          each item in roleList
            tr
              td.inner-center
                input.inner-check(type="checkbox" check-item=item.id)
              td #{item.name}
              td #{item.description}
              td #{item.deletedByAdmin || ""}
              td
                .inner-buttons
                  button.inner-undo(button-undo data-api=`/${pathAdmin}/setting/role/undo/${item.id}`)
                    i.fa-solid.fa-rotate-left
                  button.inner-delete(button-destroy data-api=`/${pathAdmin}/setting/role/destroy/${item.id}`)
                    i.fa-regular.fa-trash-can
  //- End Section 6

  //- Section 7
  .section-7
    span.inner-label Hiển thị #{pagination.startItem} - #{pagination.endItem} của #{pagination.totalRecord}
    .inner-pagination(box-pagination)
      button.inner-page.inner-page-nav(
        type="button"
        data-page=(pagination.currentPage - 1)
        disabled=(pagination.currentPage <= 1)
      ) Trước
      - for (let i = 1; i <= pagination.totalPage; ++i)
        button.inner-page(
          type="button"
          class=(pagination.currentPage === i ? "active" : "")
          data-page=i
        ) #{i}
      button.inner-page.inner-page-nav(
        type="button"
        data-page=(pagination.currentPage + 1)
        disabled=(pagination.currentPage >= pagination.totalPage)
      ) Sau
  //- End Section 7
