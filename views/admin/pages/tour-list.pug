extends ../layouts/default.pug

block main
  if (permissions.includes("tour-list"))
    h1.box-title Quản lý tour

    //- Section 4
    .section-4
      .inner-wrap
        .inner-item.inner-label
          i.fa-solid.fa-filter
          | Bộ lọc
        .inner-item
          select(filter-status)
            option(value="") Trạng thái
            option(value="active") Hoạt động
            option(value="inactive") Tạm dừng
        .inner-item
          select(filter-created-by)
            option(value="") Người tạo
            each item in userAdmin
              option(value=item.id) #{item.fullName}
        .inner-item.inner-date
          input(type="date" filter-start-date)
          span -
          input(type="date" filter-end-date)
        .inner-item
          select(filter-category)
            option(value="") Danh mục
            each item in categoryList
              option(value=item.id) #{item.name}
        .inner-item
          select(filter-price-range)
            option(value="") Mức giá
            option(value="under-2m") Dưới 2tr
            option(value="2m-4m") 2tr đến 4tr
            option(value="4m-8m") 4tr đến 8tr
            option(value="over-8m") Trên 8tr
        .inner-item.inner-reset(delete-filter-button)
          i.fa-solid.fa-rotate-left
          | Xóa bộ lọc
    //- End Section 4

    //- Section 5
    .section-5
      .inner-wrap
        .inner-change-status(change-multi data-api=`/${pathAdmin}/tour/change-multi`)
          .inner-item
            select
              option(value="") -- Hành động --
              option(value="active") Hoạt động
              option(value="inactive") Dừng hoạt động
              option(value="delete") Xóa
          .inner-item
            button Áp dụng
        .inner-search
          i.fa-solid.fa-magnifying-glass
          input(type="text" placeholder="Tìm kiếm" search)
        if (permissions.includes("tour-create"))
          .inner-button-create
            a(href=`/${pathAdmin}/tour/create`) + Tạo mới
        if (permissions.includes("tour-trash"))
          .inner-button-trash
            a(href=`/${pathAdmin}/tour/trash`) Thùng rác
    //- End Section 5

    //- Section 6
    .section-6
      .table-2
        table
          thead
            tr
              th.inner-center
                input.inner-check(type="checkbox" check-all)
              th Tên tour
              th Ảnh đại diện
              th Giá
              th Còn lại
              th.inner-center Vị trí
              th.inner-center Trạng thái
              th Tạo bởi
              th Cập nhật bởi
              th Hành động
          tbody
            each item in tourList
              tr
                td.inner-center
                  input.inner-check(type="checkbox" check-item=item.id)
                td #{item.name}
                td
                  img.inner-avatar(src=item.avatar)
                td
                  div NL: #{item.priceAdult.toLocaleString("vi-VN")}đ
                  div TE: #{item.priceChildren.toLocaleString("vi-VN")}đ
                  div EB: #{item.priceBaby.toLocaleString("vi-VN")}đ
                td
                  div NL: #{item.stockAdult}
                  div TE: #{item.stockChildren}
                  div EB: #{item.stockBaby}
                td.inner-center #{item.position}
                td.inner-center
                  if (item.status == "active")
                    .badge.badge-green Hoạt động
                  else if (item.status == "inactive")
                    .badge.badge-red Tạm dừng
                td
                  div #{item.createdByAdmin}
                  div.inner-time #{item.createdAtFormat}
                td
                  div #{item.updatedByAdmin}
                  div.inner-time #{item.updatedAtFormat}
                td
                  .inner-buttons
                    if (permissions.includes("tour-edit"))
                      a.inner-edit(href=`/${pathAdmin}/tour/edit/${item.id}`)
                        i.fa-regular.fa-pen-to-square
                    if (permissions.includes("tour-delete"))
                      button.inner-delete(button-delete data-api=`/${pathAdmin}/tour/delete/${item.id}`)
                        i.fa-regular.fa-trash-can
    //- End Section 6

    //- Section 7
    .section-7
      span.inner-label Hiển thị #{pagination.startItem} - #{pagination.endItem} của #{pagination.totalRecord}
      .inner-pagination(box-pagination)
        button.inner-page.inner-page-nav(
          type="button"
          data-page=(pagination.currentPage - 1)
          disabled=(pagination.currentPage <= 1)
        ) Trước
        - for (let i = 1; i <= pagination.totalPage; ++i)
          button.inner-page(
            type="button"
            class=(pagination.currentPage === i ? "active" : "")
            data-page=i
          ) #{i}
        button.inner-page.inner-page-nav(
          type="button"
          data-page=(pagination.currentPage + 1)
          disabled=(pagination.currentPage >= pagination.totalPage)
        ) Sau
    //- End Section 7
